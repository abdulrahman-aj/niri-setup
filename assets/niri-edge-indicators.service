[Unit]
Description=Niri off-screen column edge indicators
PartOf=graphical-session.target
After=graphical-session.target
Requisite=graphical-session.target

[Service]
ExecStart=/usr/bin/quickshell --no-duplicate --path %h/.config/quickshell/niri-edge-indicators/shell.qml
Restart=on-failure
RestartSec=1

[Install]
WantedBy=graphical-session.target
