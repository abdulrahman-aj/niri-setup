#!/usr/bin/env bash
set -euo pipefail

FONT_VERSION="${FONT_VERSION:-v3.4.0}"
FONT_URL="${FONT_URL:-https://github.com/ryanoasis/nerd-fonts/releases/download/${FONT_VERSION}/JetBrainsMono.tar.xz}"
FONT_SHA256="${FONT_SHA256:-ef552a3e638f25125c6ad4c51176a6adcdce295ab1d2ffacf0db060caf8c1582}"
HOME="${HOME:-$(eval echo ~"${USER:-$(whoami)}")}"
FONT_DIR="${FONT_DIR:-$HOME/.local/share/fonts/JetBrainsMonoNerdFont}"

font_present() {
    [[ "$(fc-match -f '%{family}\n' 'JetBrainsMono Nerd Font')" == *'JetBrainsMono Nerd Font'* ]]
}

if font_present; then
    exit 0
fi

tempdir="$(mktemp -d)"
archive="$tempdir/JetBrainsMono.tar.xz"
trap 'rm -rf "$tempdir"' EXIT

curl -fsSL "$FONT_URL" -o "$archive" || { printf 'Download failed: %s\n' "$FONT_URL" >&2; exit 1; }
[[ "$(sha256sum "$archive" | cut -d' ' -f1)" == "$FONT_SHA256" ]] || { printf 'Checksum mismatch\n' >&2; exit 1; }

mkdir -p "$FONT_DIR"
tar -xJf "$archive" -C "$FONT_DIR" --wildcards '*.ttf'
fc-cache -f "$FONT_DIR"

font_present || { printf 'JetBrainsMono Nerd Font was not discovered\n' >&2; exit 1; }
