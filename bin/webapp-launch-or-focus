#!/usr/bin/env bash
# Launch or focus a Chrome web-app window, matched by its Niri app_id.

set -euo pipefail

usage() {
    printf 'Usage: webapp-launch-or-focus <key> <url>\n' >&2
    exit 2
}

(($# == 2)) || usage
readonly KEY=$1 URL=$2 APP_ID="niri-webapp-$1"
[[ "$KEY" =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]] || { printf 'Invalid web-app key: %s\n' "$KEY" >&2; exit 2; }
[[ "$URL" == https://* ]] || { printf 'Web-app URL must use HTTPS: %s\n' "$URL" >&2; exit 2; }

exec launch-or-focus "$APP_ID" google-chrome "--app=$URL" "--class=$APP_ID"
