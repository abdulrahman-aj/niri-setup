#!/usr/bin/env bash
# Control the on-demand Docker service used by the DMS widget.

set -euo pipefail

readonly SYSTEMCTL=${SYSTEMCTL:-/usr/bin/systemctl}
readonly SUDO=${SUDO:-/usr/bin/sudo}

docker_is_active() {
    "$SYSTEMCTL" is-active --quiet docker.service
}

docker_status() {
    if docker_is_active; then
        printf 'active\n'
    else
        printf 'inactive\n'
    fi
}

docker_start() {
    "$SUDO" "$SYSTEMCTL" start docker.service docker.socket
    docker_is_active
    printf 'Docker started\n'
}

docker_stop() {
    "$SUDO" "$SYSTEMCTL" stop docker.service docker.socket
    if docker_is_active; then
        printf 'Docker did not stop\n' >&2
        return 1
    fi
    printf 'Docker stopped\n'
}

case "${1:-toggle}" in
    status) docker_status ;;
    start) docker_is_active || docker_start ;;
    stop) if docker_is_active; then docker_stop; fi ;;
    toggle) if docker_is_active; then docker_stop; else docker_start; fi ;;
    *) printf 'Usage: docker-toggle [status|start|stop|toggle]\n' >&2; exit 2 ;;
esac
