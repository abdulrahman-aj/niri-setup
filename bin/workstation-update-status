#!/usr/bin/env bash
# Report whether the managed workstation checkout is behind origin/main.

set -euo pipefail

script_path="$(readlink -f "${BASH_SOURCE[0]}")"
repo_root="$(cd "$(dirname "$script_path")/.." && pwd)"
# shellcheck source=/dev/null
source "$repo_root/lib/git-remote.sh"

readonly REPO="${NIRI_SETUP_DIR:-$HOME/.local/share/niri-setup}"
readonly EXPECTED_REMOTE="${WORKSTATION_UPDATE_REPO_URL:-https://github.com/abdulrahman-aj/niri-setup.git}"

[[ -d "$REPO/.git" ]] || { printf 'Managed checkout is missing: %s\n' "$REPO" >&2; exit 2; }
git_remote_matches "$REPO" "$EXPECTED_REMOTE" || {
    printf 'Managed checkout has an unexpected origin: %s\n' "$REPO" >&2
    exit 2
}
git -C "$REPO" fetch --quiet origin main || exit 2
behind="$(git -C "$REPO" rev-list --count HEAD..refs/remotes/origin/main)" || exit 2
((behind > 0))
