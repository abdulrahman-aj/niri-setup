#!/usr/bin/env bash
# Launch or focus a terminal UI window, matched by a derived Niri app_id.

set -euo pipefail

usage() {
    printf 'Usage: tui-launch-or-focus <command> [arguments...]\n' >&2
    exit 2
}

(($#)) || usage

name="$(basename "$1" | tr '[:upper:]_' '[:lower:]-' | sed 's/[^a-z0-9-]//g; s/^-*//; s/-*$//')"
[[ -n "$name" ]] || name=tui
[[ "$name" =~ ^[a-z] ]] || name="app-$name"
readonly APP_ID="local.tui.$name"

exec launch-or-focus "$APP_ID" xdg-terminal-exec "--app-id=$APP_ID" -- "$@"
