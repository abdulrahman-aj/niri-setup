#!/usr/bin/env bash
# shellcheck disable=SC2016 # jq programs intentionally use jq variables in single quotes.
# Launch an app or focus its existing Niri window, matched by app_id.

set -euo pipefail

readonly STATE_ROOT="${XDG_RUNTIME_DIR:-/tmp/launch-or-focus-$UID}/launch-or-focus"

usage() {
    printf 'Usage: launch-or-focus <app-id> <launch-command> [arguments...]\n' >&2
    exit 2
}

(($# >= 2)) || usage
readonly APP_ID=$1
shift
[[ "$APP_ID" =~ ^[A-Za-z0-9._-]+$ ]] || { printf 'Invalid app id: %s\n' "$APP_ID" >&2; exit 2; }

windows() { niri msg -j windows; }

focus_window() {
    [[ "$1" =~ ^[0-9]+$ ]] || return 1
    niri msg action focus-window --id "$1" >/dev/null
}

window_exists() {
    windows | jq -e --argjson id "$1" 'any(.[]; .id == $id)' >/dev/null
}

find_app_window() {
    windows | jq -r --arg app_id "$APP_ID" \
        '[.[] | select(.app_id == $app_id)] | (map(select(.is_focused)) + .)[0].id // empty'
}

new_window_id() {
    local before=$1 current
    current="$(windows)"
    jq -r --argjson before "$before" --arg app_id "$APP_ID" '
        [.[] | select(.id as $id | ($before | map(.id) | index($id) | not))] as $new
        | (($new | map(select(.is_focused))) + ($new | map(select(.app_id == $app_id))) + $new)[0].id // empty
    ' <<<"$current"
}

mkdir -p "$STATE_ROOT"
chmod 0700 "$STATE_ROOT"
readonly STATE_FILE="$STATE_ROOT/$APP_ID.window-id" LOCK_FILE="$STATE_ROOT/$APP_ID.lock"
exec 9>"$LOCK_FILE"
flock -n 9 || exit 0

if [[ -f "$STATE_FILE" ]]; then
    read -r id <"$STATE_FILE" || id=""
    if [[ "$id" =~ ^[0-9]+$ ]] && window_exists "$id"; then
        focus_window "$id"
        exit 0
    fi
    rm -f "$STATE_FILE"
fi

id="$(find_app_window)"
if [[ -n "$id" ]]; then
    printf '%s\n' "$id" >"$STATE_FILE"
    focus_window "$id"
    exit 0
fi

before="$(windows)"
setsid -f -- "$@" 9>&- >/dev/null 2>&1
for ((attempt = 0; attempt < 50; attempt++)); do
    sleep 0.1
    id="$(new_window_id "$before")"
    if [[ -n "$id" ]]; then
        printf '%s\n' "$id" >"$STATE_FILE"
        exit 0
    fi
done
printf 'Launched app but could not identify its Niri window: %s\n' "$APP_ID" >&2
exit 1
